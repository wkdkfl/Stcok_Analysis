# ───────────────────────────────────────────────────
# Stock Analyzer — Environment Variables
# ───────────────────────────────────────────────────
# 이 파일을 .env 로 복사하고 실제 API 키를 입력하세요.
# cp .env.example .env

# OpenAI (GPT-4o, GPT-4o-mini 등)
OPENAI_API_KEY=sk-...

# Anthropic (Claude Sonnet, Haiku 등)
ANTHROPIC_API_KEY=sk-ant-...

# Ollama (로컬 LLM — 기본 http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# FRED 경제 데이터 API (선택사항)
FRED_API_KEY=

# SEC EDGAR User-Agent (프로덕션용: 실제 이메일로 변경)
SEC_USER_AGENT=StockAnalyzer/1.0 (your-email@example.com)

# SSL 검증 비활성화 (회사 프록시/방화벽 환경에서만 1로 설정)
DISABLE_SSL_VERIFY=0
